{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "HabitTracker Debug",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/habit-tracker/bin/Debug/net10.0/habit-tracker.dll",
      "args": [],
      "cwd": "${workspaceFolder}/habit-tracker",
      "stopAtEntry": false,
      "console": "externalTerminal"
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}